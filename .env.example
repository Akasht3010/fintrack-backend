# Database
# Run `docker compose up -d` to start a local Postgres instance matching these defaults
DATABASE_URL=postgresql://fintrack:fintrack@localhost:5433/fintrack

# Auth
SECRET_KEY=change-me
ACCESS_TOKEN_EXPIRE_MINUTES=30

# Google OAuth (Web client — used for the backend-mediated OAuth flow)
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret

# Public URL Google redirects back to after consent (must be https, or
# http://localhost for testing) — set this to your ngrok URL when testing
# Google sign-in locally, and register {PUBLIC_BASE_URL}/api/auth/google/callback
# as an authorized redirect URI on the Web client in Google Cloud Console.
PUBLIC_BASE_URL=http://localhost:8000

# Redis (for Celery)
REDIS_URL=redis://localhost:6379/0

# Environment
ENV=development
